---
import ninetyEightCssUrl from "98.css/dist/98.css?url";

interface Props {
  postId: string;
}

const { postId } = Astro.props;
---

<upvote-button data-post-id={postId} title="Click to upvote this post!">
  <template shadowrootmode="open">
    <link rel="stylesheet" href={ninetyEightCssUrl} />
    <style>
      :host {
        display: inline-block;
      }

      button {
        align-items: center;
        cursor: pointer;
        display: inline-flex;
        gap: 0.35rem;
        justify-content: center;
        line-height: 1;
      }

      .count {
        min-width: 1ch;
      }

      .icon {
        flex: none;
        color: #222;
        font-size: 14px;
        line-height: 1;
        text-shadow: none;
      }
    </style>
    <button class="default" type="button">
      <span class="icon" aria-hidden="true">👍</span>
      <span>Upvote</span>
      <span class="count" aria-live="polite">0</span>
    </button>
  </template>
</upvote-button>

<script>
  type UpvoteResponse = {
    upvotes: number;
  };

  class UpvoteButton extends HTMLElement {
    private isSubmitting = false;

    setup = () => {
      const button = this.shadowRoot?.querySelector<HTMLButtonElement>("button");

      if (!button) return;

      button.onclick = this.handleClick;
      void this.loadUpvotes();
    };

    private handleClick = async () => {
      const postId = this.dataset.postId;
      const count = this.shadowRoot?.querySelector<HTMLSpanElement>(".count");

      if (!postId || !count || this.isSubmitting) return;

      this.isSubmitting = true;

      try {
        const response = await fetch("/api/upvote", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({ post_id: postId }),
        });

        if (!response.ok) {
          throw new Error("Failed to update upvote");
        }

        const updated = (await response.json()) as UpvoteResponse;
        count.textContent = String(updated.upvotes);
      } catch (error) {
        console.error(error);
      } finally {
        this.isSubmitting = false;
      }
    };

    private async loadUpvotes() {
      const postId = this.dataset.postId;
      const count = this.shadowRoot?.querySelector<HTMLSpanElement>(".count");

      if (!postId || !count) return;

      try {
        const response = await fetch(`/api/upvote?post_id=${postId}`);
        if (!response.ok) {
          throw new Error("Failed to GET upvote count");
        }
        const data = (await response.json()) as UpvoteResponse;
        count.textContent = String(data.upvotes);
      } catch (error) {
        console.error(error);
      }
    }
  }

  if (!customElements.get("upvote-button")) {
    customElements.define("upvote-button", UpvoteButton);
  }

  if (!window.__upvotePageLoadBound) {
    const setupUpvoteButtons = () => {
      document
        .querySelectorAll<UpvoteButton>("upvote-button")
        .forEach((button) => button.setup());
    };

    document.addEventListener("astro:page-load", setupUpvoteButtons);
    window.__upvotePageLoadBound = true;
  }
</script>
