---
import ninetyEightCssUrl from "98.css/dist/98.css?url";

interface Props {
  postId: string;
}

const { postId } = Astro.props;
---

<upvote-button data-post-id={postId} title="Click to upvote this post!">
  <template shadowrootmode="open">
    <link rel="stylesheet" href={ninetyEightCssUrl} />
    <style>
      :host {
        display: inline-block;
      }

      button {
        align-items: center;
        cursor: pointer;
        display: inline-flex;
        gap: 0.35rem;
        justify-content: center;
        line-height: 1;
      }

      .count {
        min-width: 1ch;
      }

      .icon {
        flex: none;
        color: #222;
        font-size: 14px;
        line-height: 1;
        text-shadow: none;
      }
    </style>
    <button class="default" type="button">
      <span class="icon" aria-hidden="true">👍</span>
      <span>Upvote</span>
      <span class="count" aria-live="polite">0</span>
    </button>
  </template>
</upvote-button>

<script>
  type UpvoteResponse = {
    upvotes: number;
  };

  class UpvoteButton extends HTMLElement {
    static observedAttributes = ["data-post-id"];

    private button: HTMLButtonElement | null = null;
    private count: HTMLSpanElement | null = null;
    private setupFrame: number | null = null;
    private isSubmitting = false;
    private lastLoadedPostId: string | null = null;

    connectedCallback() {
      this.scheduleSetup({ forceReload: true });
    }

    disconnectedCallback() {
      this.cancelScheduledSetup();
      this.button?.removeEventListener("click", this.handleClick);
      this.button = null;
      this.count = null;
      this.lastLoadedPostId = null;
    }

    attributeChangedCallback(name: string, oldValue: string | null, newValue: string | null) {
      if (
        name !== "data-post-id" ||
        oldValue === newValue ||
        !this.isConnected
      ) {
        return;
      }

      if (this.count) {
        this.count.textContent = "0";
      }

      this.scheduleSetup({ forceReload: true });
    }

    private scheduleSetup({ forceReload }: { forceReload: boolean }) {
      this.cancelScheduledSetup();

      const run = () => {
        if (!this.isConnected) return;

        if (!this.initializeElements()) {
          this.setupFrame = window.requestAnimationFrame(run);
          return;
        }

        this.setupFrame = null;
        this.button?.removeEventListener("click", this.handleClick);
        this.button?.addEventListener("click", this.handleClick);
        void this.loadUpvotes({ forceReload });
      };

      this.setupFrame = window.requestAnimationFrame(run);
    }

    private cancelScheduledSetup() {
      if (this.setupFrame === null) return;

      window.cancelAnimationFrame(this.setupFrame);
      this.setupFrame = null;
    }

    private initializeElements() {
      const shadowRoot = this.shadowRoot;

      if (!shadowRoot) {
        return false;
      }

      const button = shadowRoot.querySelector<HTMLButtonElement>("button");
      const count = shadowRoot.querySelector<HTMLSpanElement>(".count");

      if (!button || !count) {
        return false;
      }

      this.button = button;
      this.count = count;
      return true;
    }

    private handleClick = async () => {
      const postId = this.dataset.postId;

      if (!postId || !this.button || !this.count || this.isSubmitting) return;

      this.isSubmitting = true;

      try {
        const response = await fetch("/api/upvote", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({ post_id: postId }),
        });

        if (!response.ok) {
          throw new Error("Failed to update upvote");
        }

        const updated = (await response.json()) as UpvoteResponse;
        this.count.textContent = String(updated.upvotes);
      } catch (error) {
        console.error(error);
      } finally {
        this.isSubmitting = false;
      }
    };

    private async loadUpvotes({ forceReload = false }: { forceReload?: boolean } = {}) {
      const postId = this.dataset.postId;

      if (!postId || !this.count) return;
      if (!forceReload && this.lastLoadedPostId === postId) return;

      this.lastLoadedPostId = postId;

      try {
        const response = await fetch(`/api/upvote?post_id=${postId}`);
        if (!response.ok) {
          throw new Error("Failed to GET upvote count");
        }
        const data = (await response.json()) as UpvoteResponse;
        this.count.textContent = String(data.upvotes);
      } catch (error) {
        this.lastLoadedPostId = null;
        console.error(error);
      }
    }
  }

  if (!customElements.get("upvote-button")) {
    customElements.define("upvote-button", UpvoteButton);
  }
</script>
