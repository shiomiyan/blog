---
import { getTagLabel } from "@lib/taxonomy";

type Props = {
  tag: string;
  count?: number;
};

const { tag, count } = Astro.props;
const displayName = getTagLabel(tag);
---

<a href={`/tags/${tag}`} class="ui-badge" aria-label={`tag: ${displayName}`}>
  {displayName}{count !== undefined && ` (${count})`}
</a>
