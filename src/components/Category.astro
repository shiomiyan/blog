---
import { getCategoryLabel, type CategoryId } from "@lib/taxonomy";

type Props = {
  category: CategoryId;
  count?: number;
};

const { category, count } = Astro.props;
const displayName = getCategoryLabel(category);
---

<a
  href={`/categories/${category}`}
  class="rounded-lg border border-black/15 px-2 py-0.5 font-mono text-xs hover:bg-gray-200"
  aria-label={`category: ${displayName}`}
>
  {displayName}{count !== undefined && ` (${count})`}
</a>
