---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import EntryList from "@components/EntryList.astro";
import { getCategoryDefinitions, getCategoryLabel } from "@lib/taxonomy";

export const prerender = true;

export const getStaticPaths: GetStaticPaths = async () => {
  const categoryDefinitions = await getCategoryDefinitions();
  return categoryDefinitions.map((category) => ({
    params: { slug: category.id },
  }));
};

const { slug } = Astro.params as { slug: string };
const posts = (await getCollection("posts"))
  .filter((post) => !post.data.draft)
  .filter((post) => post.data.category === slug);

const categoryDisplayName = await getCategoryLabel(slug);
const meta = {
  description: `Posts in category ${categoryDisplayName}`,
  title: `category: ${categoryDisplayName}`,
};
---

<Layout title={meta.title} description={meta.description}>
  <EntryList entries={posts} />
</Layout>
