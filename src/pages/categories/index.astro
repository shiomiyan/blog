---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import Category from "@components/Category.astro";
import { getCollection } from "astro:content";
import { getCategoryDefinitions } from "@lib/taxonomy";

export const prerender = true;

const categoryDefinitions = getCategoryDefinitions();
const posts = (await getCollection("posts")).filter((post) => !post.data.draft);

const categoryCounts = Object.fromEntries(
  categoryDefinitions.map((category) => [category.id, 0]),
) as Record<string, number>;

for (const { data } of posts) {
  categoryCounts[data.category] = (categoryCounts[data.category] ?? 0) + 1;
}

const categories = categoryDefinitions.map((category) => ({
  slug: category.id,
  count: categoryCounts[category.id] ?? 0,
}));

const meta = {
  description: "A list of all categories",
  title: "Categories",
};
---

<Layout {...meta}>
  <Container>
    <div class="mt-10" data-pagefind-ignore="all">
      <div class="space-y-4">
        <section class="space-y-4">
          <ul
            class="grid list-none grid-cols-2 gap-2 md:grid-cols-3 lg:grid-cols-4"
          >
            {
              categories.map((category) => (
                <li>
                  <Category category={category.slug} count={category.count} />
                </li>
              ))
            }
          </ul>
        </section>
      </div>
    </div>
  </Container>
</Layout>
