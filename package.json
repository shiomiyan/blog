{
  "name": "blog.736b.moe",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24 <25"
  },
  "pnpm": {
    "overrides": {
      "vite": "7.3.2"
    }
  },
  "scripts": {
    "dev": "astro dev",
    "build": "pnpm run cf-typegen && pnpm run typecheck && astro check && astro build",
    "check:all": "pnpm run lint && pnpm run typecheck && pnpm run astro -- check && pnpm run textlint",
    "preview": "astro preview",
    "deploy": "pnpm run build && wrangler deploy",
    "astro": "astro",
    "lint": "eslint .",
    "typecheck": "tsc --NoEmit",
    "cf-typegen": "wrangler types --path ./src/worker-configuration.d.ts",
    "textlint": "textlint \"README.md\" \"AGENTS.md\" \"src/content/posts/**/*.md\" \"src/content/posts/**/*.mdx\"",
    "format": "prettier --write .",
    "create-post": "tsx bin/create-post.ts"
  },
  "devDependencies": {
    "98.css": "^0.1.21",
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^13.1.10",
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@eslint/js": "^10.0.1",
    "@pagefind/default-ui": "^1.5.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@typescript-eslint/parser": "^8.59.0",
    "arctic": "^3.7.0",
    "astro": "^6.1.7",
    "eslint": "^10.2.0",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.5.0",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rehype-external-links": "^3.0.0",
    "tailwindcss": "^4.2.2",
    "textlint": "^15.5.4",
    "textlint-filter-rule-allowlist": "^4.0.0",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "wrangler": "^4.83.0"
  }
}
